{
  "manifest_version": 3,
  "name": "AI Job Agent",
  "version": "1.0.0",
  "description": "Semi-manual AI job application assistant.",
  "action": {},
  "options_page": "dashboard.html",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.jsx"]
    }
  ]
}